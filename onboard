#!/usr/bin/env bash
# onboard — interactive setup menu. Run as `~/config/onboard`.

set -u

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
. "$SCRIPT_DIR/lib/ui.sh"
. "$SCRIPT_DIR/lib/onboard.sh"

DOTFILES_DIR="$SCRIPT_DIR/dotfiles.templates"
XDG_DIR="$SCRIPT_DIR/xdg_config.templates"

MISE_TOOLS=(
  jq
  yq
  fd
  ripgrep
  lazygit
  delta
  yazi
  fzf
  zoxide
)

ob__extend_path

pause() {
  printf '\n%s[Enter 로 계속]%s ' "$UI_DIM" "$UI_RESET"
  read -r _ || true
}

# apply_file SRC DEST — copy SRC to DEST if DEST does not exist.
apply_file() {
  local src="$1" dest="$2"
  if [ ! -f "$src" ]; then
    printf '%s!%s missing template: %s\n' "$UI_YELLOW" "$UI_RESET" "$src"
    return 1
  fi
  if [ -e "$dest" ]; then
    printf '%s!%s %s already exists; skipping\n' "$UI_YELLOW" "$UI_RESET" "$dest"
    return 0
  fi
  mkdir -p "$(dirname -- "$dest")"
  cp "$src" "$dest"
  printf '%s✓%s copied to %s\n' "$UI_GREEN" "$UI_RESET" "$dest"
}

# apply_rc_source SRC TAG — ensure `. SRC` is sourced from ~/.bashrc and ~/.zshrc.
# Idempotent: uses a marker line tagged with TAG.
apply_rc_source() {
  local src="$1" tag="$2"
  local marker="#~/config:${tag}:source"
  local rc line
  line="[ -f \"$src\" ] && . \"$src\" ${marker}"
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    [ -f "$rc" ] || touch "$rc"
    if grep -Fq "$marker" "$rc" 2>/dev/null; then
      printf '%s=%s %s already sources %s\n' "$UI_DIM" "$UI_RESET" "$rc" "$tag"
    else
      printf '\n%s\n' "$line" >> "$rc"
      printf '%s+%s %s now sources %s\n' "$UI_GREEN" "$UI_RESET" "$rc" "$src"
    fi
  done
}

pick_mise_tools() {
  local -a labels=()
  local -a presel=()
  local i tool
  for ((i=0; i<${#MISE_TOOLS[@]}; i++)); do
    tool="${MISE_TOOLS[$i]}"
    if ob_tool_installed "$tool"; then
      labels[$i]="$tool ${UI_DIM}(installed)${UI_RESET}"
    else
      labels[$i]="$tool"
      presel+=($i)
    fi
  done
  ui_multiselect "mise 글로벌 설치 대상" labels "${presel[*]:-}"
  if [ -z "$UI_CHOICES" ]; then
    printf '취소됨\n'
    return 0
  fi
  local -a picked=()
  for i in $UI_CHOICES; do
    picked+=("${MISE_TOOLS[$i]}")
  done
  if [ ${#picked[@]} -eq 0 ]; then
    printf '선택 없음\n'
    return 0
  fi
  echo
  ob_install_mise_tools "${picked[@]}"
}

# ---- install actions ----

do_recommend() {
  printf '\n%s== Recommend ==%s\n' "$UI_BOLD" "$UI_RESET"
  ob_install_brew
  echo
  ob_install_mise
  echo
  pick_mise_tools
}

do_brew() {
  printf '\n%s== Brew ==%s\n' "$UI_BOLD" "$UI_RESET"
  ob_install_brew
}

do_mise() {
  printf '\n%s== Mise ==%s\n' "$UI_BOLD" "$UI_RESET"
  ob_install_mise
  echo
  pick_mise_tools
}

# ---- config actions ----

do_gitconfig() {
  printf '\n%s== gitconfig ==%s\n' "$UI_BOLD" "$UI_RESET"
  apply_file "$DOTFILES_DIR/.gitconfig" "$HOME/.gitconfig"
}

do_nanorc() {
  printf '\n%s== nanorc ==%s\n' "$UI_BOLD" "$UI_RESET"
  apply_file "$DOTFILES_DIR/.nanorc" "$HOME/.nanorc"
}

do_tmux() {
  printf '\n%s== tmux.conf ==%s\n' "$UI_BOLD" "$UI_RESET"
  apply_file "$DOTFILES_DIR/.tmux.conf" "$HOME/.tmux.conf"
  tmux source-file "$HOME/.tmux.conf" 2>/dev/null || true
}

do_ghostty() {
  printf '\n%s== ghostty ==%s\n' "$UI_BOLD" "$UI_RESET"
  apply_file "$XDG_DIR/ghostty/config" "$HOME/.config/ghostty/config"
}

do_tm_properties() {
  printf '\n%s== tm_properties ==%s\n' "$UI_BOLD" "$UI_RESET"
  apply_file "$DOTFILES_DIR/.tm_properties" "$HOME/.tm_properties"
}

# ---- ai-config actions ----

do_opencode() {
  printf '\n%s== opencode ==%s\n' "$UI_BOLD" "$UI_RESET"
  local f
  for f in "$XDG_DIR"/opencode/opencode-*.json; do
    [ -f "$f" ] || continue
    apply_file "$f" "$HOME/.config/opencode/$(basename "$f")"
  done
  apply_rc_source "$XDG_DIR/opencode/.bashrc.template" "opencode"
}

do_claude() {
  printf '\n%s== claude ==%s\n' "$UI_BOLD" "$UI_RESET"
  apply_rc_source "$DOTFILES_DIR/.claude/.bashrc.template" "claude"
}

# ---- submenus ----

submenu_install() {
  local -a labels actions
  while true; do
    printf '\033[H\033[2J'
    local brew_tag="" mise_tag=""
    ob_has brew && brew_tag=" ${UI_GREEN}(installed)${UI_RESET}"
    ob_has mise && mise_tag=" ${UI_GREEN}(installed)${UI_RESET}"
    labels=(
      "Recommend — brew + mise + global tools"
      "Brew 설치${brew_tag}"
      "Mise 설치${mise_tag}"
      "← back"
    )
    actions=(
      do_recommend
      do_brew
      do_mise
      __back
    )
    ui_menu "install" labels
    [ "$UI_CHOICE" = "255" ] && return 0
    local fn="${actions[$UI_CHOICE]}"
    [ "$fn" = "__back" ] && return 0
    "$fn"
    pause
  done
}

submenu_config() {
  local -a labels actions
  while true; do
    printf '\033[H\033[2J'
    labels=(
      "gitconfig"
      "nanorc"
      "tmux"
      "ghostty"
      "tm_properties"
      "← back"
    )
    actions=(
      do_gitconfig
      do_nanorc
      do_tmux
      do_ghostty
      do_tm_properties
      __back
    )
    ui_menu "config" labels
    [ "$UI_CHOICE" = "255" ] && return 0
    local fn="${actions[$UI_CHOICE]}"
    [ "$fn" = "__back" ] && return 0
    "$fn"
    pause
  done
}

submenu_ai_config() {
  local -a labels actions
  while true; do
    printf '\033[H\033[2J'
    labels=(
      "opencode"
      "claude"
      "← back"
    )
    actions=(
      do_opencode
      do_claude
      __back
    )
    ui_menu "ai-config" labels
    [ "$UI_CHOICE" = "255" ] && return 0
    local fn="${actions[$UI_CHOICE]}"
    [ "$fn" = "__back" ] && return 0
    "$fn"
    pause
  done
}

do_exit() {
  printf '\nbye.\n'
  exit 0
}

main() {
  local -a labels actions
  labels=(
    "install"
    "config"
    "ai-config"
    "Exit"
  )
  actions=(
    submenu_install
    submenu_config
    submenu_ai_config
    do_exit
  )
  while true; do
    printf '\033[H\033[2J'
    ui_menu "onboard" labels
    if [ "$UI_CHOICE" = "255" ]; then
      do_exit
    fi
    local fn="${actions[$UI_CHOICE]}"
    "$fn"
  done
}

main "$@"
