# claude aliases
alias ccrdsp='claude --model opus --resume --dangerously-skip-permissions'
alias ccodsp='claude --model opus --dangerously-skip-permissions'
# opencode alias
alias openglm='OPENCODE_CONFIG="$HOME/.config/opencode/config-ollama-glm.json" opencode'
alias opengpt='OPENCODE_CONFIG="$HOME/.config/opencode/config-openai-gpt.json" opencode'
